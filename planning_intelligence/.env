# Azure Blob Storage Configuration
BLOB_CONNECTION_STRING=<YOUR_BLOB_CONNECTION_STRING>
BLOB_CONTAINER_NAME=planning-data
BLOB_CURRENT_FILE=current.csv
BLOB_PREVIOUS_FILE=previous.csv

# Azure OpenAI Configuration
AZURE_OPENAI_KEY=<YOUR_AZURE_OPENAI_KEY>
AZURE_OPENAI_ENDPOINT=<YOUR_AZURE_OPENAI_ENDPOINT>
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.2-chat
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Azure Functions Configuration
FUNCTIONS_WORKER_RUNTIME=python
AzureWebJobsStorage=<YOUR_AZURE_WEBJOBS_STORAGE>

# Local Development
CORS_ORIGIN=http://localhost:3000

# CSV File Configuration (for local development)
CSV_DATA_PATH=../sample_data
CSV_CURRENT_FILE=planning_data_10000_records.csv
CSV_USE_BLOB=false

# Snapshot Storage Configuration (for local development)
SNAPSHOT_FILE_PATH=./planning_snapshot.json

# Ollama Configuration (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=120

# OpenAI/Azure OpenAI Configuration
OPENAI_TIMEOUT=120
